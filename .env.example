# GitLab credentials (self-hosted)
# Get your PAT at: https://your-gitlab.example.com/-/user_settings/personal_access_tokens
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_TOKEN=your-personal-access-token

# Optional: profile name (defaults to "env")
GITLAB_PROFILE=my-gitlab

# Optional: default project ID or path (e.g. "group/subgroup/repo" or "123")
GITLAB_DEFAULT_PROJECT=group/subgroup/repo
